# Firebase — copie para .env e preencha com as chaves do seu projeto
# (console.firebase.google.com > Configurações do projeto > Seus apps > SDK).
# Sem estas variáveis, o app roda em "modo visitante" (sem login/sync).
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# RevenueCat (assinaturas) — Fase 1
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=

# Narração em nuvem (opcional) — Google Cloud Text-to-Speech.
# Sem isto, o app usa a voz do próprio aparelho. Com a chave, usa vozes
# WaveNet/Neural (bem mais naturais). Voz padrão: pt-BR-Neural2-B (masculina).
EXPO_PUBLIC_GOOGLE_TTS_KEY=
EXPO_PUBLIC_GOOGLE_TTS_VOICE=pt-BR-Neural2-B

# Professor de Teologia (agente IA) — escolha UM dos modos:
# PRODUÇÃO: URL da sua Cloud Function (server/agent-proxy/) — a chave fica no servidor.
EXPO_PUBLIC_AGENT_API_URL=
# DEV (somente testes!): chave da Anthropic direto no app. NÃO publique o app assim.
EXPO_PUBLIC_ANTHROPIC_KEY=
# Modelo (opcional; padrão claude-opus-4-8)
EXPO_PUBLIC_AGENT_MODEL=
